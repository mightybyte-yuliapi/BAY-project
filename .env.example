# Copy this file to `.env.local` and fill in real values for local dev.
# In production, set the same keys in Vercel → Project → Settings → Environment Variables.
# All of these are SERVER-SIDE only (no NEXT_PUBLIC_ prefix) — never exposed to the browser.

# ── OpenAI Realtime API ────────────────────────────────────────────────
# Used by src/app/api/realtime/session/route.ts to mint ephemeral tokens.
OPENAI_API_KEY=sk-...

# ── SendGrid (email tool) ──────────────────────────────────────────────
# Used by the send_email agent tool to email call summaries / follow-ups.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
# Must be a SendGrid-VERIFIED sender (single sender or authenticated domain).
SENDGRID_FROM_EMAIL=you@your-verified-domain.com
SENDGRID_FROM_NAME=AppMakers USA
# Recipients of the end-of-call qualification report — comma-separated list.
REPORT_RECIPIENTS=aaron@mightybyte.us, bradley@mightybyte.us
